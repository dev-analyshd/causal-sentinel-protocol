# ─── Causal Sentinel Protocol — Environment Variables ────────────────────────
# Copy to .env and fill in values.
# NEVER commit .env to git.

# Casper Network
CASPER_NODE=https://rpc.testnet.casper.network
CHAIN_ID=688689
CASPER_KEY=./keys/sentinel.pem

# Contract hashes (filled after deployment)
SENTINEL_REGISTRY_HASH=hash-
SENTINEL_VAULT_HASH=hash-
SENTINEL_LEARNER_HASH=hash-
COMPLIANCE_ENGINE_HASH=hash-
EPISTATIC_CONTROLLER_HASH=hash-
ZK_VERIFIER_HASH=hash-

# Security (generate with: openssl rand -hex 32)
ADMIN_SECRET=CHANGE_ME_IN_PRODUCTION
X402_HMAC_KEY=CHANGE_ME_IN_PRODUCTION

# Database
DB_PASSWORD=csp_dev

# AI Services (optional — for ANIMA crawler)
ANTHROPIC_API_KEY=
CMC_API_KEY=

# Frontend
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080
